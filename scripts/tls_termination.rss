use pingora;
let downstream: int = pingora::tcp::downstream();
let scheme: string = pingora::request::scheme();

if scheme == "tcp" {
    let prefix: string = pingora::tcp::peek(downstream, 4);
    if prefix == "GET " || prefix == "POST" || prefix == "HEAD" {
        pingora::downstream::attach_http();
        pingora::response::insert_header("x-termination", "plain-http");
    } else {
        let session: int = pingora::tls::accept(downstream);
        pingora::tls::set_alpn(session, "h2,http/1.1");
        pingora::tls::set_sni(session, "gateway.local");
        if pingora::tls::handshake(session) {
            pingora::downstream::attach_http();
            pingora::response::insert_header("x-termination", "tls");
            pingora::response::insert_header("x-tls-alpn", pingora::tls::alpn(session));
            pingora::response::insert_header("x-tls-peer", pingora::tls::peer_name(session));
        } else {
            pingora::tcp::close(downstream);
            pingora::runtime::exit();
        }
    }
}

pingora::response::set_status(201);
pingora::response::set_body(pingora::request::method() + "|" + pingora::request::path_with_query());