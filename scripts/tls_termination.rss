use http;
use runtime;
use tcp;
use tls;

let downstream: int = tcp::stream::downstream();
let scheme: string = http::request::get_scheme();

if scheme == "tcp" {
    let prefix: string = tcp::stream::peek(downstream, 4);
    if prefix == "GET " || prefix == "POST" || prefix == "HEAD" {
        http::downstream::attach_transport();
        http::response::set_header("x-termination", "plain-http");
    } else {
        let session: int = tls::session::from_socket(downstream);
        tls::session::set_alpn(session, "h2,http/1.1");
        tls::session::set_sni(session, "gateway.local");
        if tls::session::handshake(session) {
            http::downstream::attach_transport();
            http::response::set_header("x-termination", "tls");
            http::response::set_header("x-tls-alpn", tls::session::get_alpn(session));
            http::response::set_header("x-tls-peer", tls::session::get_peer_name(session));
        } else {
            tcp::stream::close(downstream);
            runtime::exit();
        }
    }
}

http::response::set_status(201);
http::response::set_body(http::request::get_method() + "|" + http::request::get_path_with_query());
