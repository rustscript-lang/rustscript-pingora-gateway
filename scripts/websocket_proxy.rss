use http;
use proxy;
use websocket;

let downstream: int = websocket::connection::downstream();
http::response::set_header("x-downstream-ws", websocket::connection::get_phase(downstream));

let upstream: int = websocket::connection::default_upstream();
websocket::connection::set_target(upstream, "127.0.0.1", 18091);
websocket::connection::set_path(upstream, "/echo");
websocket::connection::set_subprotocols(upstream, "chat,superchat");
websocket::connection::connect(upstream);

let mut message: string = http::request::get_header("x-ws-message");
if message == "" {
    message = "pingora-websocket";
}
websocket::connection::send_text(upstream, message);
let reply: string = websocket::connection::read_text(upstream);

let down_stream: int = proxy::stream::downstream();
let up_stream: int = proxy::stream::from_websocket_binary(upstream);
let proxy_status: string = proxy::bridge(down_stream, up_stream, 8);

http::response::set_status(200);
http::response::set_header("x-ws-protocol", websocket::connection::get_subprotocol(upstream));
http::response::set_header("x-proxy-status", proxy_status);
http::response::set_body(reply);
websocket::connection::close(upstream, 1000, "complete");
http::response::set_header("x-ws-phase", websocket::connection::get_phase(upstream));
