use pingora;
let downstream: int = pingora::websocket::downstream();
pingora::response::insert_header("x-downstream-ws", pingora::websocket::phase(downstream));

let upstream: int = pingora::websocket::default_upstream();
pingora::websocket::set_peer(upstream, "127.0.0.1", 18091);
pingora::websocket::set_path(upstream, "/echo");
pingora::websocket::set_subprotocols(upstream, "chat,superchat");
pingora::websocket::connect(upstream);

let mut message: string = pingora::request::header("x-ws-message");
if message == "" {
    message = "pingora-websocket";
}
pingora::websocket::send_text(upstream, message);
let reply: string = pingora::websocket::read_text(upstream);

let down_stream: int = pingora::proxy::downstream_stream();
let up_stream: int = pingora::proxy::websocket_binary_stream(upstream);
let proxy_status: string = pingora::proxy::bridge(down_stream, up_stream, 8);

pingora::response::set_status(200);
pingora::response::insert_header("x-ws-protocol", pingora::websocket::subprotocol(upstream));
pingora::response::insert_header("x-proxy-status", proxy_status);
pingora::response::set_body(reply);
pingora::websocket::close(upstream, 1000, "complete");
pingora::response::insert_header("x-ws-phase", pingora::websocket::phase(upstream));