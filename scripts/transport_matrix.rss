use pingora;

let tcp_stream: int = pingora::tcp::new();
pingora::tcp::set_peer(tcp_stream, "127.0.0.1", 19000);
pingora::tcp::connect(tcp_stream);
pingora::tcp::write(tcp_stream, "hello-tcp");

let session: int = pingora::tls::accept(tcp_stream);
pingora::tls::set_verify(session, false);
pingora::tls::set_alpn(session, "edge/1");
pingora::tls::handshake(session);

pingora::response::set_status(200);
pingora::response::insert_header("x-tcp-phase", pingora::tcp::phase(tcp_stream));
pingora::response::insert_header("x-tls-phase", pingora::tls::phase(session));
pingora::response::insert_header("x-tls-alpn", pingora::tls::alpn(session));
pingora::response::set_body("transport matrix ok");
