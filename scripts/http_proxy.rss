use pingora;
let path: string = pingora::request::path();
let client: string = pingora::request::header("x-client-id");

if !pingora::limits::allow(client, 100, 60) {
    pingora::response::set_status(429);
    pingora::response::insert_header("x-rustscript-action", "rate-limited");
    pingora::response::set_body("rate limited");
} else {
    let exchange: int = pingora::upstream::default();
    pingora::upstream::set_peer(exchange, "127.0.0.1", 18080);
    pingora::upstream::set_path(exchange, path);
    pingora::upstream::insert_header(exchange, "x-forwarded-by", "rustscript-pingora");

    if pingora::request::header("x-stream") != "" {
        pingora::upstream::send(exchange);
        pingora::response::set_status(pingora::upstream::status(exchange));
        pingora::response::insert_header("content-type", pingora::upstream::header(exchange, "content-type"));
        let mut body = "";
        while !pingora::upstream::body_eof(exchange) {
            body = body + pingora::upstream::body_next_chunk(exchange, 8);
        }
        pingora::response::set_body(body);
        pingora::response::insert_header("x-rustscript-action", "streaming-proxy");
    } else {
        let downstream: int = pingora::proxy::downstream_stream();
        let upstream: int = pingora::proxy::upstream_stream(exchange);
        let status: string = pingora::proxy::forward(downstream, upstream, 16);
        pingora::response::set_status(200);
        pingora::response::insert_header("x-proxy-status", status);
        pingora::response::insert_header("x-rustscript-action", "native-proxy");
    }
}